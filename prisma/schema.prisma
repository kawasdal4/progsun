// SISNAS PERATURAN BASARNAS
// Sistem Penyusunan dan Database Nasional Peraturan & Pedoman

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  relationMode = "prisma"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String
  role        UserRole  @default(VIEWER)
  unitKerja   String?
  jabatan     String?
  nip         String?
  isActive    Boolean   @default(true)
  avatar      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditLogs   AuditLog[]
  regulations Regulation[]      @relation("RegulationAuthor")
  comments    Comment[]
  versions    RegulationVersion[]
}

enum UserRole {
  SUPER_ADMIN
  PENYUSUN_WILAYAH
  PENYUSUN_PUSAT
  REVIEWER_HUKUM
  PIMPINAN
  VIEWER
}

// ============================================
// REGULATION DOCUMENT
// ============================================

model Regulation {
  id                  String   @id @default(cuid())
  
  // Basic Info
  jenis               JenisRegulasi
  nomor               String?
  tahun               Int
  tentang             String
  
  // Workflow
  status              RegulationStatus @default(DRAFT_WILAYAH)
  unitKerja           String?
  
  // Versioning
  version             Int      @default(1)
  currentSnapshotId   String?
  
  // Structured Content (JSON)
  header              Json
  konsiderans         Json
  diktum              Json
  batangTubuh         Json
  penutup             Json
  lampiran            Json?
  
  // PDF
  pdfPath             String?
  
  // Relations
  createdById         String
  createdBy           User     @relation("RegulationAuthor", fields: [createdById], references: [id])
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  finalizedAt         DateTime?
  dicabutAt           DateTime?
  
  // Related models
  versions            RegulationVersion[]
  sourceRelations     RegulationRelation[] @relation("SourceRelation")
  targetRelations     RegulationRelation[] @relation("TargetRelation")
  comments            Comment[]
  searchIndex         SearchIndex?
  auditLogs           AuditLog[]
  approvals           ApprovalRecord[]
}

enum JenisRegulasi {
  PERATURAN_BADAN
  PEDOMAN
  KEPUTUSAN
  SURAT_EDARAN
}

enum RegulationStatus {
  DRAFT_WILAYAH
  REVIEW_SUBSTANSI
  REVIEW_HUKUM
  REVISI
  MENUNGGU_PERSETUJUAN
  FINAL
  DICABUT
}

// ============================================
// VERSIONING
// ============================================

model RegulationVersion {
  id             String   @id @default(cuid())
  regulationId   String
  regulation     Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  versionNumber  Int
  changeSummary  String
  snapshot       Json
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
}

// ============================================
// REGULATION RELATIONS
// ============================================

model RegulationRelation {
  id              String   @id @default(cuid())
  sourceId        String
  source          Regulation @relation("SourceRelation", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId        String
  target          Regulation @relation("TargetRelation", fields: [targetId], references: [id], onDelete: Cascade)
  relationType    RelationType
  description     String?
  createdAt       DateTime @default(now())
}

enum RelationType {
  MENGUBAH
  MENCABUT
  MENJADI_DASAR
  PERUBAHAN_ATAS
}

// ============================================
// COMMENTS & NOTES
// ============================================

model Comment {
  id             String   @id @default(cuid())
  regulationId   String
  regulation     Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  content        String
  section        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  resolved       Boolean  @default(false)
  resolvedAt     DateTime?
  resolvedById   String?
}

// ============================================
// APPROVAL RECORDS
// ============================================

model ApprovalRecord {
  id             String   @id @default(cuid())
  regulationId   String
  regulation     Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  approvedById   String
  action         ApprovalAction
  notes          String?
  createdAt      DateTime @default(now())
}

enum ApprovalAction {
  APPROVED
  REJECTED
  REQUEST_REVISION
}

// ============================================
// AUDIT LOG (IMMUTABLE)
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  details     Json
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  regulationId String?
  regulation   Regulation? @relation(fields: [regulationId], references: [id])
}

// ============================================
// SEARCH INDEX
// ============================================

model SearchIndex {
  id             String   @id @default(cuid())
  regulationId   String   @unique
  regulation     Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  content        String
  updatedAt      DateTime @default(now())
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        NotificationType
  entityId    String?
  entityType  String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  APPROVAL_REQUIRED
  STATUS_CHANGE
  COMMENT
}

// ============================================
// SETTINGS
// ============================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
